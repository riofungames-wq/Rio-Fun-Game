notes: /* empty */
libs:
  random: {}
  fittoscreen:
    manageViewport: true
    mode: scaleFill
  place: {}
  keyboard.polyfill: {}
  keyboard: {}
  vkeys: {}
  touch: {}
  mouse: {}
  tween: {}
  transition: {}
  gamepad: {}
  sound.howler:
    defaultMaxDistance: 2500
    useDepth: false
    manageListenerPosition: true
types:
  - name: Box
    depth: 0
    oncreate: |-
      this.canMove = (direction) => {
          return !ct.place.tile(this, this.x + direction, this.y, -10) &&
              ct.place.free(this, this.x + direction, this.y, 'Solid') && 
              (ct.place.tile(this, this.x, this.y + 10, -10) ||
              !ct.place.free(this, this.x, this.y + 10, 'Solid'));
      }
    onstep: |-
      /*
      if (ct.place.meet(this, this.x + 5, this.y, 'Player') &&
          !ct.place.tile(this, this.x - 10, this.y, -10) &&
          ct.place.free(this, this.x - 10, this.y, 'Solid')) {
          this.x -= 10;
      }
      if (ct.place.meet(this, this.x - 5, this.y, 'Player') &&
          !ct.place.tile(this, this.x + 10, this.y, -10) &&
          ct.place.free(this, this.x + 10, this.y, 'Solid')) {
          this.x += 10;
      }
      */
      if (!ct.place.tile(this, this.x, this.y + 10, -10) &&
          ct.place.free(this, this.x, this.y + 10, 'Solid')
      ) {
          this.y += 10;
      }
    ondraw: ''
    ondestroy: ''
    uid: b7a528f8-655c-4920-900f-f191533f411d
    lastmod: 1621300756681
    extends:
      ctype: Solid
    texture: d8dd2bfd-0f9d-495a-bbfd-0e65b80153b9
