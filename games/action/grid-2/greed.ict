    texture: eed6bb2f-301f-460a-8d91-93396d103b4e
  - name: Player
    depth: 0
    oncreate: |
      this.animationSpeed = 15 / 60;

      // Traditional speed/dir movement system works badly with platformers.
      // We will set up our own variables and write own movement code.

      this.maxspeed = 5; // this will be our max horizontal speed
      this.acceleration = 1; // this is walking acceleration
      this.jumpPower = 12; // this is our jumping velocity
      this.gravity = 0.5;


      // Camera should follow the character

      ct.camera.follow = this;
      ct.camera.borderX = 400;
      ct.camera.borderY = 200;
      ct.camera.drift = 0.95;
    onstep: "if (this.suspension > 1) {\n    this.suspension--;\n    return;\n}\nelse if (this.suspension === 1) {\n    ct.sound.spawn('BodyFall');\n    ct.rooms.switch('DeadScreen');\n}\n\nif (this.goodSuspension > 1) {\n    this.goodSuspension--;\n    return;\n}\nelse if (this.goodSuspension === 1) {\n    ct.rooms.switch('RichScreen');\n}\n\n\n// here and below we check for both collisions with tiles and copies.\n// -10 is the depth of the colliding tile layer. We ignore the decorative\n// layer at -20.\nvar onGround = ct.place.occupied(this, this.x, this.y + 1, 'Solid') ||\n               ct.place.tile(this, this.x, this.y + 1, -10);\n\n// Move right or left\nif (ct.actions.Move.value > 0.5) {\n    if (this.hspeed < this.maxspeed) {\n        this.hspeed += this.acceleration;\n    }\n    if ((this.currentFrame > 10 || !this.playing) && onGround) {\n        this.gotoAndPlay(0);\n    }\n} else if (ct.actions.Move.value < -0.5) {\n    if (this.hspeed > -this.maxspeed) {\n        this.hspeed -= this.acceleration;\n    }\n    if ((this.currentFrame > 10 || !this.playing) && onGround) {\n        this.gotoAndPlay(0);\n    }\n} else { // Slow down if we are on the ground and we don't move.\n    if (onGround) {\n        this.speed = Math.max(0, this.speed - this.maxspeed);\n        this.gotoAndStop(9);\n    } else if (!ct.actions.Move.pressed) {\n        // Don't move if we are not pressing the move button\n        this.hspeed = 0;\n    }\n}\n\n\n// If we are not on the ground, add gravity\nif (!onGround) {\n    this.vspeed += this.gravity * ct.delta;\n    if (this.currentFrame > 9 && this.currentFrame !== 12) {\n\t\tthis.gotoAndStop(11);\n\t}\n}\n\n// Jumping\nif (ct.actions.Jump.down) {\n    // Jump only if we stay on the ground\n    if (onGround) {\n        this.vspeed = -this.jumpPower;\n        this.gotoAndStop(12);\n    }\n}\n\n// Jumping and forward\nif (ct.actions.JumpAndForward.down) {\n    // Jump only if we stay on the ground\n    if (onGround) {\n        this.vspeed = -this.jumpPower;\n        if (this.hspeed === 0) {\n            this.inAirForward = 1 * this.scale.x;\n            this.hspeed = 1 * this.scale.x;\n        }\n        this.gotoAndStop(12);\n    }\n}\n\nif (this.inAirForward) {\n    if (!ct.actions.JumpAndForward.down) {\n        this.inAirForward = 0;\n    }\n    else {\n        this.hspeed = this.inAirForward;\n    }\n}\n\n// Move pixel by pixel until we meet a colliding object next to us\n//\n// Premultiply the target speed with ct.delta to ensure the same movement\n// over different FPS.\n//\n// Math.sign returns -1 if a number is negative, 1 if positive and 0 if it is 0.\n// Math.abs turns everything into a positive number.\n// Combined, Math.abs and Math.sign allow to loop in any direction.\nvar boxException\nfor (var i = 0; i < Math.abs(this.hspeed * ct.delta); i++) {\n    if (ct.place.free(this, this.x + Math.sign(this.hspeed), this.y, 'Solid') &&\n        !ct.place.tile(this, this.x + Math.sign(this.hspeed), this.y, -10)\n    ) {\n        this.x += Math.sign(this.hspeed);\n    } else if (!ct.place.tile(this, this.x + Math.sign(this.hspeed), this.y, -10)) {\n        var isItJustABox = ct.place.occupied(this, this.x + Math.sign(this.hspeed), this.y, 'Solid', true);\n        if (isItJustABox.length === 1 && isItJustABox[0].type === 'Box' && isItJustABox[0].canMove(Math.sign(this.hspeed))) {\n            this.x += Math.sign(this.hspeed);\n            isItJustABox[0].x += Math.sign(this.hspeed);\n        }\n        else {\n            this.hspeed = 0;\n            break;\n        }\n    } else {\n        this.hspeed = 0;\n        break;\n    } \n}\n\n\n// Do the same for vertical speed\nfor (var i = 0; i < Math.abs(this.vspeed * ct.delta); i++) {\n    if (ct.place.free(this, this.x, this.y + Math.sign(this.vspeed), 'Solid') &&\n        !ct.place.tile(this, this.x, this.y + Math.sign(this.vspeed), -10)\n    ) {\n        this.y += Math.sign(this.vspeed);\n    } else {\n        var isItJustABox = ct.place.occupied(this, this.x, this.y + Math.sign(this.vspeed), 'Solid', true);\n        var isItSameBox = ct.place.occupied(this, this.x + Math.sign(this.hspeed), this.y, 'Solid');\n        if (!ct.place.tile(this, this.x, this.y + Math.sign(this.vspeed), -10) /* there is no tile */\n            && isItJustABox.length === 1 && isItJustABox[0].type === 'Box' /* the occupied space is a box */\n            && isItJustABox[0] === isItSameBox /* no skiing - i.e. riding a box on its side */) {\n            this.y += Math.sign(this.vspeed);\n        }\n        else {\n            this.vspeed = 0;\n            break;\n        }\n    }\n}\n\n// Check if we collide with spikes\nif (ct.place.occupied(this, this.x, this.y, 'Enemy')) {\n    this.suspension = 5;\n}\n"
    ondraw: |-
      if (this.hspeed < 0) {
          this.scale.x = -1;
      } else if (this.hspeed > 0) {
          this.scale.x = 1;
      }

      ct.camera.shiftX = this.scale.x * 150;
    ondestroy: ''
    uid: 00664f77-21c6-4b06-b310-88640b1beaf9
    lastmod: 1623632174747
    extends:
      ctype: Player
    texture: ad390b6e-4c2c-412f-8143-1c70b9c16fc0
  - name: Coin
    depth: 0
    oncreate: ''
    onstep: |-
      if (ct.place.meet(this, this.x, this.y, 'Player') && !this.kill) {
          this.kill = true;
          ct.sound.spawn(ct.random.dice('Coin_01', 'Coin_02', 'Coin_03'));
          ct.room.coins ++;
      }
    ondraw: ''
    ondestroy: ''
    uid: 9402709c-5d0d-4198-9dce-877a5b7c77a2
    lastmod: 1621129701458
