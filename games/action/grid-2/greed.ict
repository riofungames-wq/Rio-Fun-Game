    lastmod: 1621257227691
  - name: TryAgain
    depth: 0
    oncreate: ''
    onstep: >


      if (ct.mouse.hovers(this) && this.currentFrame !== 2 + (this.nextWorld ? 0
      : 1)) {
          this.gotoAndStop(2 + (this.nextWorld ? 0 : 1));
      }

      else if (!ct.mouse.hovers(this) && this.currentFrame !== 0 +
      (this.nextWorld ? 0 : 1)) {
          this.gotoAndStop(0 + (this.nextWorld ? 0 : 1));
      }


      if (ct.touch.collide(this) || (this.isMain && ct.actions.Enter.pressed) ||
      (this.nextWorld && ct.actions.Restart.pressed) || (ct.mouse.hovers(this)
      && ct.mouse.pressed) || (this.isMain && ct.gamepad.getButton('Button1'))
      || (this.isAlternative && ct.gamepad.getButton('Button2'))) {

          window.touchPause = Date.now();
          if (this.isMain && this.nextWorld) {
              switch (window.activeRoom) {
                  case 1:
                      ct.rooms.switch('InGame2');
                  break;
                  case 2:
                      ct.rooms.switch('InGame3');
                  break;
                  default:
                      ct.rooms.switch('Title');
                  break;
              }
          }
          else if (this.nextWorld) {
              ct.rooms.switch('Title');
          }
          else {
              switch (window.activeRoom) {
                  case 3:
                      ct.rooms.switch('InGame3');
                  break;
                  case 2:
                      ct.rooms.switch('InGame2');
                  break;
                  default:
                      ct.rooms.switch('InGame');
                  break;
              }
          }

      }
    ondraw: ''
    ondestroy: ''
    uid: 64fac189-737e-4e56-a8fc-15eccae6bf2a
    texture: 0298d848-efe7-48e5-8d68-9128ba8b4e02
    extends: {}
    lastmod: 1622120856641
  - name: Reload
    depth: 100
    oncreate: |
      this.button = ct.vkeys.button({
          key: "Vk5",
          texNormal: "reload",
          texActive: "reload",
          texHover: "reload",
          x: () => this.x,
          y: () => this.y,
          depth: 1000
      });
      this.button.visible = false;
    onstep: |-
      if (ct.actions.Restart.pressed) {
          ct.rooms.switch('DeadScreen');
      }
    ondraw: |
      this.button.x = this.x;
      this.button.y = this.y;
    ondestroy: ''
    texture: 5bb12d21-9254-4d3a-9052-b972154978ed
