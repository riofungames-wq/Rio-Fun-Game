  - name: InGame2
    oncreate: |
      ct.transition.fadeIn(400, 0xc7f2f5);

      this.coins = 0;
      window.totalCoins = 26;

      ct.rooms.append('UI_Layer', {isUi: true});

      window.activeRoom = 2;
      window.wasResized = false;
    onstep: |
      if (this.coins >= window.totalCoins) {
          if (!ct.types.list['Player'][0].goodSuspension) ct.types.list['Player'][0].goodSuspension = 24;
      }
    ondraw: |
      if (window.innerHeight > window.innerWidth && !window.wasResized) {
          ct.camera.scale.y = 0.7;
          ct.camera.scale.x = 0.7;
          ct.camera.borderY = null;
          window.wasResized = true;
      }
      else if (window.innerHeight < window.innerWidth && window.wasResized) {
          ct.camera.scale.y = 1.0;
          ct.camera.scale.x = 1.0;
          ct.camera.borderY = 200;
          window.wasResized = false;
      }
    onleave: ''
    width: 1024
    height: 700
