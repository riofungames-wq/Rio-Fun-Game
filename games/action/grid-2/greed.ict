  - name: DeadScreen
    oncreate: >-
      ct.sound.spawn('Failure');


      this.ohNoLabel = new PIXI.Text('Oh no!', ct.styles.get('OhNo'));

      this.ohNoLabel.x = 1024 / 2;

      this.ohNoLabel.y = 520;

      this.ohNoLabel.anchor.x = this.ohNoLabel.anchor.y = 0.5;

      this.addChild(this.ohNoLabel);


      this.greedyLabel = new PIXI.Text('You were too greeedy for that game!',
      ct.styles.get('OhNo_Small'));

      this.greedyLabel.x = 1024 / 2;

      this.greedyLabel.y = 560;

      this.greedyLabel.anchor.x = this.greedyLabel.anchor.y = 0.5;

      this.addChild(this.greedyLabel);
    onstep: ''
    ondraw: ''
    onleave: ''
