  - name: Greed
    depth: 0
    oncreate: ''
    onstep: ''
    ondraw: ''
    ondestroy: ''
    uid: 2d29a0d5-d88d-493d-bece-8d52ed476273
    lastmod: 1621255591955
    extends: {}
    texture: e90eb23b-547a-4d96-a203-ffe63c00cf9b
  - name: Slime
    depth: 0
    oncreate: |-
      this.speed = 1;
      this.direction = -180;

      this.animationSpeed = 4 / 60;
      this.play();
    onstep: >-
      var freeBelow = !ct.place.tile(this, this.x + ct.u.ldx(70,
      this.direction), this.y + 35, -10) &&
                      ct.place.free(this, this.x + ct.u.ldx(70, this.direction), this.y + 35, 'Solid');

      var occupiedInFront = ct.place.tile(this, this.x + ct.u.ldx(10,
      this.direction), this.y, -10) ||
                            ct.place.occupied(this, this.x + ct.u.ldx(10, this.direction), this.y, 'Solid');

      var isOnTop = ct.place.occupied(this, 'Solid');


      if (isOnTop) {
          this.kill = true;
          ct.sound.spawn('Splat');
      }


      if (freeBelow || occupiedInFront) {
          if (this.direction === 180) {
              this.direction = 0;
              this.scale.x = -1;
          } else {
              this.direction = 180;
              this.scale.x = 1;
          }
      }


      this.move();
    ondraw: ''
    ondestroy: ''
    uid: 1f91fd7d-2d6c-4542-aead-78b8010b835b
    lastmod: 1621127643791
    extends:
      ctype: Enemy
    texture: 703fb5d5-cf20-4450-b760-0b1cd037a5ad
  - name: Rich
