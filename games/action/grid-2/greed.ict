  - name: ButtonJump
    depth: 0
    oncreate: |
      this.button = ct.vkeys.button({
          key: "Vk4",
          texNormal: "buttonJump",
          texActive: "buttonJump",
          texHover: "buttonJump",
          x: () => this.x,
          y: () => this.y,
          depth: 1000
      });
      this.alpha = 0.5;
      this.button.visible = false;
    onstep: ''
    ondraw: >
      this.button.x = this.x;

      this.button.y = this.y;

      this.button.scale.x = window.wasResized ? 2.0 : 1.0;

      this.button.scale.y = window.wasResized ? 2.0 : 1.0;

      this.scale.x = (window.wasResized ? 2.0 : 1.0) *
      ct.types.list['Player'][0].scale.x;

      this.scale.y = window.wasResized ? 2.0 : 1.0;
    ondestroy: ''
