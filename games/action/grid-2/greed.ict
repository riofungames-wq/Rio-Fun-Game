    lastmod: 1621226476476
  - name: Button
    depth: 0
    oncreate: |-
      this.doneOffset = 0;
      try {
          this.doneOffset = localStorage.getItem("greedii_level" + this.world + "_done") ? 2 : 0;
      }
      catch (e) {
          console.warn("Local storage has failed - maybe the user is in Private Browsing")
      }
      this.gotoAndStop(0 + this.doneOffset);
    onstep: >-
      if (ct.mouse.hovers(this) && this.currentFrame !== 1 + this.doneOffset &&
      !window.gamepadSelect) {
          this.gotoAndStop(1 + this.doneOffset);
      }

      else if (!ct.mouse.hovers(this) && this.currentFrame !== 0 +
      this.doneOffset && !window.gamepadSelect) {
          this.gotoAndStop(0 + this.doneOffset);
      }

      else if (ct.gamepad.getAxis('LStickY') > 0.7) {
          window.gamepadSelect = 2;
          if (this.world === 2 && this.currentFrame !== 1 + this.doneOffset) {
              this.gotoAndStop(1 + this.doneOffset);
          }
          else if (this.world != 2 && this.currentFrame !== 0 + this.doneOffset) {
              this.gotoAndStop(0 + this.doneOffset);
          }
      }

      else if (ct.gamepad.getAxis('LStickX') > 0.7) {
          window.gamepadSelect = 3;
          if (this.world === 3 && this.currentFrame !== 1 + this.doneOffset) {
              this.gotoAndStop(1 + this.doneOffset);
          }
          else if (this.world != 3 && this.currentFrame !== 0 + this.doneOffset) {
              this.gotoAndStop(0 + this.doneOffset);
          }
      }

      else if (ct.gamepad.getAxis('LStickX') < -0.7) {
          window.gamepadSelect = 1;
          if (this.world === 1 && this.currentFrame !== 1 + this.doneOffset) {
              this.gotoAndStop(1 + this.doneOffset);
          }
          else if (this.world != 1 && this.currentFrame !== 0 + this.doneOffset) {
              this.gotoAndStop(0 + this.doneOffset);
          }
      }


      if (ct.actions.Enter.pressed || ct.keyboard.lastKey === '1') {
          ct.keyboard.clear();
          ct.rooms.switch('InGame');
      }

      else if (ct.keyboard.lastKey === '2') {
          ct.keyboard.clear();
          ct.rooms.switch('InGame2');
      }

      else if (ct.keyboard.lastKey === '3') {
          ct.keyboard.clear();
          ct.rooms.switch('InGame3');
      }


      if ((ct.touch.collide(this) && Date.now() > (window.touchPause || 0) +
      1000) || (ct.mouse.pressed && ct.mouse.hovers(this)) ||
      (ct.gamepad.getButton('Button1') && window.gamepadSelect === this.world))
      {
          window.gamepadSelect = undefined;
          switch (this.world) {
              case 1:
                  ct.rooms.switch('InGame');
              break;
              case 2:
                  ct.rooms.switch('InGame2');
              break;
              default:
                  ct.rooms.switch('InGame3');
              break;
          }
      }
    ondraw: ''
    ondestroy: ''
    texture: 95379108-a9a4-48a2-8dc2-bcdf749107aa
    extends: {}
    uid: e3851f67-0e32-4882-b0a0-4fc5a0d63905
