  - name: Spikes
    depth: 0
    oncreate: ''
    onstep: ''
    ondraw: ''
    ondestroy: ''
    uid: 036a2de1-89b0-48e3-b26f-d608ce2079fd
    lastmod: 1621084782188
    extends:
