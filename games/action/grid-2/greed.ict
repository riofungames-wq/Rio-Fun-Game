  - name: RichScreen
    oncreate: >-
      ct.sound.spawn('Victory');


      try {
          localStorage.setItem("greedii_level" + window.activeRoom + "_done", "1");
      }

      catch (e) {
          console.warn("Local storage has failed - maybe the user is in Private Browsing")
      }


      ct.keyboard.clear();


      this.ohNoLabel = new PIXI.Text('You got them all!',
      ct.styles.get('OhNo'));

      this.ohNoLabel.x = 1024 / 2;

      this.ohNoLabel.y = 490;

      this.ohNoLabel.anchor.x = this.ohNoLabel.anchor.y = 0.5;

      this.addChild(this.ohNoLabel);


      this.subLabel = new PIXI.Text('You\'ve found all the coins.
      Congrats!\nThank you for playing!', ct.styles.get('OhNo_Small'));

      this.subLabel.x = 1024 / 2;

      this.subLabel.y = 550;

      this.subLabel.anchor.x = this.subLabel.anchor.y = 0.5;

      this.addChild(this.subLabel);
