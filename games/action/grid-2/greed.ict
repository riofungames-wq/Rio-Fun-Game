  - name: ToggleFullscreen
    depth: 100
    oncreate: ''
    onstep: |-
      if (ct.mouse.pressed && ct.mouse.hoversUi(this)) {
          ct.fittoscreen.toggleFullscreen();
      }

      if (ct.touch.enabled && ct.touch.hoversUi(this)) {
          ct.fittoscreen.toggleFullscreen();
      }
    ondraw: 'this.gotoAndStop(ct.fittoscreen.getIsFullscreen()? 1 : 0);'
    ondestroy: ''
